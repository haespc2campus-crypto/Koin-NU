# Server
PORT=5173
DATA_DIR=data
UPLOADS_DIR=uploads

# PostgreSQL (Rizquna/server). Jika kosong, fallback ke DATA_DIR/db.json.
DATABASE_URL=postgres://koin_nu_user:***@localhost:5432/koin_nu

# Security/runtime
# Min 30m enforced.
SESSION_TTL_MS=43200000
# Clamped 64KB..10MB.
MAX_BODY_BYTES=2097152
